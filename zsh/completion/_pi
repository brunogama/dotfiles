_pi_model_patterns() {
  local -a models
  models=(
    'sonnet:Anthropic Sonnet fuzzy match'
    'opus:Anthropic Opus fuzzy match'
    'haiku:Anthropic Haiku fuzzy match'
    'gpt-5.5:OpenAI Codex default model'
    'gpt-5.4:OpenAI/GitHub Copilot default model'
    'gemini-3.1-pro-preview:Google default model'
    'anthropic/*:All Anthropic models'
    'openai/*:All OpenAI models'
    'openai-codex/*:All OpenAI Codex models'
    'github-copilot/*:All GitHub Copilot models'
    'google/*:All Google Gemini models'
    '*sonnet*:Any Sonnet model'
  )
  _describe -t models 'model pattern' models "$@"
}

_pi_model_list() {
  local -a models
  models=(
    sonnet
    opus
    haiku
    gpt-5.5
    gpt-5.4
    gemini-3.1-pro-preview
    'anthropic/*'
    'openai/*'
    'openai-codex/*'
    'github-copilot/*'
    'google/*'
    '*sonnet*'
  )
  _values -s , 'model pattern' "${models[@]}"
}

_pi_tools() {
  local -a tools
  tools=(
    'read:Read file contents'
    'bash:Execute bash commands'
    'edit:Edit files with find/replace'
    'write:Write files'
    'grep:Search file contents'
    'find:Find files by glob pattern'
    'ls:List directory contents'
    'ask_question:Ask a structured user question'
  )
  _values -s , 'tool' "${tools[@]}"
}

_pi_session_files() {
  _files -g '*.jsonl'
}

_pi "$@"
