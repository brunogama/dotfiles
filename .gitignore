# Ignore sensitive information and secrets
**/secrets
**/*.log
**/logs/
**/gcloud/logs/

# Ignore cache files
**/.DS_Store
**/cache/

# Specific app data that might contain sensitive information
iterm2/AppSupport
iterm2/sockets/
github-copilot
swiftpm
gh
raycast


# Local configuration that shouldn't be shared
mise/local.toml

# Temporary files
**/tmp/
**/*.tmp

# Zsh specific files
zsh/.zsh_history
zsh/.zprezto
zsh/.zsh_sessions
# Ignore build artifacts
**/build/
# Ignore IDE specific files
**/.idea/
# Ignore Python cache files
**/__pycache__/
# Ignore Jupyter Notebook checkpoints
**/.ipynb_checkpoints/
# Ignore virtual environments
**/venv/
# Ignore macOS specific files
**/.DS_Store
# Ignore Python egg files
**/*.egg-info/


### OSX ###
# General
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

gcloud

# Database files
**/*.sqlite
**/*.db
**/*.sql

# Other potentially sensitive data
**/*.p12
**/*.pfx
**/*.passwd

# macOS Keychain files
**/*.keychain
**/*.keychain-db

# Credential helpers
**/credentials.json
**/client_secrets.json
**/*-credentials.json

# Authentication files and tokens
**/*.pem
**/*.key
**/*.crt
**/*.cer
**/*.der
**/id_rsa*
**/.ssh/
**/*.pub
**/known_hosts
**/*_token
**/*.keystore
**/*.jks
**/.netrc

# Environment variables and configuration files
**/.env*
**/.aws/
**/.boto
**/terraformrc
**/.npmrc
**/.yarnrc
**/.bundle/config