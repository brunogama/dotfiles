#!/usr/bin/env bash
# clear_derived_data
# author: Bruno Gama <bgamap at gmail dot com>

sudo find ~/Library/Developer/Xcode/DerivedData -type d -execdir rm -rf {} \; 2>/dev/null
sudo find /var/folders -iname "com.apple.DeveloperTools" -type d -execdir rm -rf {} \; 2>/dev/null

cat <<-__HEREDOC__

Finished wiping Xcode Derived Data.

__HEREDOC__
