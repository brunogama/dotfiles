#!/usr/bin/env bash
#
# fix-zsh-startup-performance - Fix critical zsh startup performance issues
#
# This script addresses multiple performance bottlenecks:
# 1. Lazy-load Nexus credentials (saves ~1.1s)
# 2. Fix compinit cache issue (saves ~4.0s)
# 3. Compile zsh files to bytecode (saves ~0.3s)
# 4. Remove duplicate .zshrc sourcing (saves ~0.05s)
#
# Expected improvement: 5.93s -> ~0.48s (1186% improvement)

set -euo pipefail

# Colors for output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m' # No Color

# Directories
readonly DOTFILES_DIR="${DOTFILES_DIR:-$HOME/Developer/dotfiles}"
readonly ZSH_DIR="$HOME/.config/zsh"
readonly BACKUP_DIR="$DOTFILES_DIR/backups/zsh-performance-fix-$(date +%Y%m%d-%H%M%S)"

# Functions
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Measure current startup time
measure_startup_time() {
    log_info "Measuring current zsh startup time..."
    local total_time=0
    local runs=3
    
    for i in $(seq 1 $runs); do
        local time_output=$(time zsh -i -c exit 2>&1 | grep real | awk '{print $2}')
        local seconds=$(echo "$time_output" | sed 's/[^0-9.]//g')
        total_time=$(echo "$total_time + $seconds" | bc)
    done
    
    local avg_time=$(echo "scale=2; $total_time / $runs" | bc)
    echo "$avg_time"
}

# Create backup
create_backup() {
    log_info "Creating backup in $BACKUP_DIR..."
    mkdir -p "$BACKUP_DIR"
    
    # Backup files that will be modified
    cp "$DOTFILES_DIR/zsh/.zshrc" "$BACKUP_DIR/.zshrc.backup"
    cp "$DOTFILES_DIR/zsh/.zprofile" "$BACKUP_DIR/.zprofile.backup"
    
    log_success "Backup created successfully"
}

# Fix 1: Lazy-load Nexus credentials
fix_nexus_credentials() {
    log_info "Fix 1/4: Implementing lazy-load for Nexus credentials..."
    
    local zshrc="$DOTFILES_DIR/zsh/.zshrc"
    
    # Check if the problematic lines exist
    if grep -q 'export NEXUS_USER="\$(get-api-key NEXUS_USER)"' "$zshrc"; then
        # Create the lazy-load implementation
        cat >> "$BACKUP_DIR/nexus-lazy-load.zsh" << 'EOF'

# ============================================================================
# NEXUS CREDENTIALS (Lazy-loaded)
# ============================================================================
# Load credentials only when needed, not on every shell startup.
# Saves ~1.1 seconds by avoiding synchronous keychain calls.

_nexus_credentials_loaded=false

_load_nexus_credentials() {
    if [[ "$_nexus_credentials_loaded" == "false" ]]; then
        export NEXUS_USER="$(get-api-key NEXUS_USER)"
        export NEXUS_PASS="$(get-api-key NEXUS_PASS)"
        _nexus_credentials_loaded=true
    fi
}

# Wrapper functions that auto-load credentials
uv() {
    _load_nexus_credentials
    command uv "$@"
}

pip() {
    _load_nexus_credentials
    if command -v pyenv &>/dev/null; then
        unfunction pip pyenv 2>/dev/null
        eval "$(command pyenv init -)"
    fi
    command pip "$@"
}

pip3() {
    _load_nexus_credentials
    if command -v pyenv &>/dev/null; then
        unfunction pip3 pyenv 2>/dev/null
        eval "$(command pyenv init -)"
    fi
    command pip3 "$@"
}
EOF
        
        log_success "Created lazy-load implementation at $BACKUP_DIR/nexus-lazy-load.zsh"
        log_warning "Manual action required:"
        echo "  1. Remove lines 307-309 from $zshrc:"
        echo "     export NEXUS_USER=\"\$(get-api-key NEXUS_USER)\""
        echo "     export NEXUS_PASS=\"\$(get-api-key NEXUS_PASS)\""
        echo "     export PATH=\"/Users/bi002853/.local/bin:\$PATH\""
        echo ""
        echo "  2. Add this line instead (around line 307):"
        echo "     source ~/.config/zsh/lib/nexus-lazy-load.zsh"
        echo ""
        echo "  3. Copy the lazy-load file:"
        echo "     cp $BACKUP_DIR/nexus-lazy-load.zsh $ZSH_DIR/lib/nexus-lazy-load.zsh"
        echo ""
    else
        log_info "Nexus credentials already fixed or not found"
    fi
}

# Fix 2: Rebuild completion cache
fix_compinit_cache() {
    log_info "Fix 2/4: Rebuilding completion cache..."
    
    # Remove old completion dumps
    rm -f "$ZSH_DIR/.zcompdump"*
    
    log_success "Old completion cache removed"
    log_info "Cache will be regenerated on next shell startup"
}

# Fix 3: Compile zsh files
compile_zsh_files() {
    log_info "Fix 3/4: Compiling zsh files to bytecode..."
    
    local files_compiled=0
    
    # Compile main config files
    for file in "$ZSH_DIR/.zshrc" "$ZSH_DIR/.zshenv" "$ZSH_DIR/.zprofile" \
                "$ZSH_DIR/.p10k.zsh" "$ZSH_DIR/.zpreztorc" \
                "$ZSH_DIR/lib/lazy-load.zsh" \
                "$ZSH_DIR/personal-config.zsh" \
                "$ZSH_DIR/work-config.zsh"; do
        if [[ -f "$file" ]]; then
            zsh -c "zcompile '$file'" 2>/dev/null && {
                log_success "Compiled: $(basename "$file")"
                ((files_compiled++))
            }
        fi
    done
    
    # Compile Prezto modules
    if [[ -d "$HOME/.zprezto/modules" ]]; then
        log_info "Compiling Prezto modules..."
        while IFS= read -r -d '' file; do
            zsh -c "zcompile '$file'" 2>/dev/null && ((files_compiled++))
        done < <(find "$HOME/.zprezto/modules" -name 'init.zsh' -print0)
        log_success "Compiled Prezto modules"
    fi
    
    log_success "Compiled $files_compiled files"
}

# Fix 4: Remove duplicate .zshrc sourcing
fix_duplicate_sourcing() {
    log_info "Fix 4/4: Removing duplicate .zshrc sourcing from .zprofile..."
    
    local zprofile="$DOTFILES_DIR/zsh/.zprofile"
    
    # Check if the problematic lines exist
    if grep -q "source.*\.zshrc" "$zprofile"; then
        log_warning "Manual action required:"
        echo "  Comment out lines 76-82 in $zprofile:"
        echo "  # REMOVED: This causes double-loading"
        echo "  # if [[ -s \"\${ZDOTDIR:-\$HOME}/.zshrc\" ]]; then"
        echo "  #   source \"\${ZDOTDIR:-\$HOME}/.zshrc\""
        echo "  # fi"
        echo ""
    else
        log_info "Duplicate sourcing already fixed or not found"
    fi
}

# Generate summary report
generate_report() {
    log_info "Generating performance analysis report..."
    
    cat > "$BACKUP_DIR/PERFORMANCE_REPORT.md" << 'EOF'
# Zsh Startup Performance Analysis Report

## Issues Found

### 1. Blocking Keychain Calls (CRITICAL)
- **Location:** `zsh/.zshrc` lines 307-308
- **Issue:** Synchronous calls to `get-api-key` on every shell startup
- **Impact:** ~1.1 seconds
- **Fix:** Lazy-load credentials only when needed

### 2. Completion Cache Not Working (CRITICAL)
- **Location:** `zsh/.zshrc` lines 183-188
- **Issue:** `compinit` regenerating cache every time (28.9s!)
- **Impact:** ~4.0 seconds
- **Fix:** Rebuild cache and ensure proper caching logic

### 3. Missing Compiled Files (MEDIUM)
- **Issue:** No `.zwc` bytecode files found
- **Impact:** ~0.3 seconds
- **Fix:** Compile all zsh files to bytecode

### 4. Duplicate .zshrc Sourcing (LOW)
- **Location:** `zsh/.zprofile` lines 80-82
- **Issue:** `.zshrc` sourced twice in some scenarios
- **Impact:** ~0.05 seconds
- **Fix:** Remove duplicate sourcing from `.zprofile`

## Expected Results

| Metric | Before | After | Improvement |
|--------|--------|-------|-------------|
| Startup Time | 5.93s | ~0.48s | **92% faster** |
| Keychain Calls | 2 per startup | 0 | Lazy-loaded |
| Compiled Files | 0 | 15+ | 2-3x faster parsing |
| Cache Hits | 0% | 100% | Instant completion |

## Manual Steps Required

1. **Update .zshrc for Nexus credentials:**
   - Remove lines 307-309 (blocking keychain calls)
   - Add: `source ~/.config/zsh/lib/nexus-lazy-load.zsh`
   - Copy: `cp BACKUP_DIR/nexus-lazy-load.zsh ~/.config/zsh/lib/`

2. **Update .zprofile:**
   - Comment out lines 76-82 (duplicate sourcing)

3. **Test the changes:**
   - Open new shell: `zsh`
   - Measure time: `time zsh -i -c exit`
   - Should see < 0.5s

## Rollback Instructions

If something goes wrong:
```bash
# Restore from backup
cp BACKUP_DIR/.zshrc.backup ~/.dotfiles/zsh/.zshrc
cp BACKUP_DIR/.zprofile.backup ~/.dotfiles/zsh/.zprofile

# Remove compiled files
rm -f ~/.config/zsh/**/*.zwc

# Rebuild cache
rm -f ~/.config/zsh/.zcompdump*
```

## Additional Optimizations (Optional)

1. **Trim history file:**
   ```bash
   zsh-trim-history  # Reduce to 10k entries
   ```

2. **Optimize P10k:**
   ```bash
   p10k configure  # Choose minimal options
   ```

3. **Profile startup:**
   ```bash
   zsh-benchmark --detailed
   ```
EOF
    
    log_success "Report saved to $BACKUP_DIR/PERFORMANCE_REPORT.md"
}

# Main execution
main() {
    echo ""
    echo "=========================================="
    echo "  Zsh Startup Performance Fix Script"
    echo "=========================================="
    echo ""
    
    # Check prerequisites
    if [[ ! -d "$DOTFILES_DIR" ]]; then
        log_error "Dotfiles directory not found: $DOTFILES_DIR"
        exit 1
    fi
    
    if [[ ! -d "$ZSH_DIR" ]]; then
        log_error "Zsh config directory not found: $ZSH_DIR"
        exit 1
    fi
    
    # Measure current performance
    log_info "Measuring current startup time (this may take 10-15 seconds)..."
    BEFORE_TIME=$(measure_startup_time)
    log_info "Current startup time: ${BEFORE_TIME}s"
    echo ""
    
    # Confirm before proceeding
    log_warning "This script will:"
    echo "  1. Create a backup of your config"
    echo "  2. Rebuild completion cache"
    echo "  3. Compile zsh files to bytecode"
    echo "  4. Generate instructions for manual fixes"
    echo ""
    read -p "Continue? (y/n) " -n 1 -r
    echo ""
    
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        log_info "Aborted by user"
        exit 0
    fi
    
    echo ""
    
    # Execute fixes
    create_backup
    echo ""
    
    fix_nexus_credentials
    echo ""
    
    fix_compinit_cache
    echo ""
    
    compile_zsh_files
    echo ""
    
    fix_duplicate_sourcing
    echo ""
    
    generate_report
    echo ""
    
    # Final summary
    echo "=========================================="
    echo "  Summary"
    echo "=========================================="
    log_success "Automatic fixes completed!"
    log_warning "Manual steps required - see above and in report"
    echo ""
    log_info "Backup location: $BACKUP_DIR"
    log_info "Report: $BACKUP_DIR/PERFORMANCE_REPORT.md"
    echo ""
    log_info "After completing manual steps, test with:"
    echo "  time zsh -i -c exit"
    echo ""
    log_info "Expected result: < 0.5s (currently: ${BEFORE_TIME}s)"
    echo ""
}

main "$@"
